
//1. Declaracion de modulo y sus I/O
module alu(
	input [31:0] A,
	input [31:0] B,
	input [2:0] alu_op,
	output reg [31:0] result
);

//2. Cables o registros

//3. Cuerpo del modulo, assigns, instancias y bloque secuencial
always @(*) begin
	case (alu_op)
		3'b000: result = A & B;                                  // AND
		3'b001: result = A | B;                                  // OR
		3'b010: result = A + B;                                  // SUMA
		3'b100: result = ~(A | B);                               // NOR
		3'b110: result = A - B;                                  // RESTA
		3'b111: result = ($signed(A) < $signed(B)) ? 32'd1 : 32'd0; // SLT
		default: result = 32'b0;
	endcase
end

endmodule