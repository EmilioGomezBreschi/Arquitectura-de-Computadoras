`timescale 1ns/1ns

module ALU_tb;

reg  [15:0] A;
reg  [15:0] B;

wire [15:0] SUMA;
wire [15:0] RESTA;
wire [15:0] MULT;
wire [15:0] DIV;
wire [15:0] AND;
wire [15:0] OR;
wire [15:0] SHL1;
wire [15:0] XOR;

ALU uut (
    .A(A),
    .B(B),
    .SUMA(SUM),
    .RESTA(RES),
    .MULT(MUL),
    .DIV(DIV),
    .AND(AND),
    .OR(OR),
    .SHL1(SHL1),
    .XOR(XOR)
);

initial begin
    A = ; B = ; #10;
    A = ; B = ; #10;
    A = ; B = ; #10;
    A = ;  B = ; #10;
    A = ;  B = ; #10;
	
	$stop;
end

endmodule
